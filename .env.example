# =============================================================================
# Configuración de PapaScan. Copiá este archivo a ".env" y ajustá lo que haga
# falta. Todas las variables tienen defaults razonables para uso local offline,
# así que .env es OPCIONAL salvo que cambies usuario/clave de la BD o el modelo.
#
#   cp .env.example .env        (macOS/Linux)
#   copy .env.example .env      (Windows CMD)
# =============================================================================

# --- PostgreSQL --------------------------------------------------------------
# Si usás el docker-compose incluido, estos valores ya coinciden.
PAPASCAN_DB_USER=postgres
PAPASCAN_DB_PASSWORD=postgres
PAPASCAN_DB_HOST=127.0.0.1
PAPASCAN_DB_PORT=5432
PAPASCAN_DB_NAME=papascan
# Alternativa: una sola URL completa (tiene prioridad si se define)
# PAPASCAN_DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/papascan

# --- Seguridad (JWT) ---------------------------------------------------------
# IMPORTANTE: poné una clave larga y propia en cualquier despliegue real.
PAPASCAN_SECRET_KEY=cambia-esta-clave-en-produccion-32+chars
PAPASCAN_TOKEN_MINUTES=720

# --- LLM local (Ollama) ------------------------------------------------------
OLLAMA_HOST=http://127.0.0.1:11434
PAPASCAN_LLM_MODEL=qwen3-vl:2b
PAPASCAN_LLM_TEMPERATURE=0.2
PAPASCAN_LLM_TIMEOUT=120

# --- Almacenamiento ----------------------------------------------------------
# PAPASCAN_STORAGE=./storage
PAPASCAN_LOW_CONF=0.60
